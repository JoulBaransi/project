# Flask API image — owns all logic (retrieval, DB, Ollama calls).
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /srv

# Install deps first for better layer caching.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# App code, the static frontend (served by Flask), and the assets ingest needs
# at runtime (corpus + SQL schema files).
COPY app/ ./app/
COPY frontend/ ./frontend/
COPY db/ ./db/
COPY data/ ./data/

EXPOSE 5000

# Production WSGI server (not the Flask dev server). Long timeout because a
# /load ingest embeds ~484 lines and /ask runs local generation.
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "2", "--timeout", "180", "app.api:app"]
