# Copy to .env and adjust. NEVER commit the real .env (see .gitignore).
# All app config is read from these env vars — nothing is hardcoded.

# ---- MySQL (official mysql:9 image in docker-compose) ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=stripe_rag_pw
DB_NAME=stripe_rag

# ---- Ollama (local only — never a cloud API) ----
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2:3b

# ---- Flask API ----
API_HOST=0.0.0.0
API_PORT=5000

# ---- Streamlit UI (used from phase d onward) ----
UI_PORT=8501
# Where the Streamlit UI reaches the Flask API:
API_BASE_URL=http://localhost:5000
